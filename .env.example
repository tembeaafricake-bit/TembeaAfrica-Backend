# ─── SERVER ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── DATABASE ───────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/tembea-africa
# Production: mongodb+srv://user:pass@cluster.mongodb.net/tembea-africa

# ─── AUTH ────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2025
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-2025
JWT_EXPIRES_IN=24h

# ─── GOOGLE OAUTH ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ─── REDIS ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── CLOUDINARY ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ─── PAYMENTS ────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox  # or 'live'

# ─── EMAIL (RESEND) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
FROM_EMAIL=noreply@tembeaafrica.com

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ─── MAPS ────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── SMS (AFRICA'S TALKING) ──────────────────────────────────────────────────
AT_API_KEY=your-africas-talking-api-key
AT_USERNAME=your-africas-talking-username
